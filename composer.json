{
  "name": "mpc/mpc-vidply",
  "title": "VidPly - Universal, Accessible Video & Audio Player",
  "description": "Universal, Accessible Video & Audio Player for TYPO3. Includes support for HTML5 video/audio, YouTube, Vimeo, SoundCloud, HLS and DASH streaming, playlists, captions, transcripts, sign language, and WCAG 2.2 AA accessibility compliance.",
  "homepage": "https://github.com/MatthiasPeltzer/mpc-vidply",
  "authors": [
    {
      "name": "Matthias Peltzer",
      "email": "mail@mpeltzer.de",
      "homepage": "https://www.mpeltzer.de/",
      "role": "Developer"
    }
  ],
  "type": "typo3-cms-extension",
  "version": "1.2.15",
  "license": ["GPL-2.0-or-later"],
  "require": {
    "php": "^8.2",
    "typo3/cms-core": "^13.4 || ^14.3",
    "typo3/cms-fluid": "^13.4 || ^14.3",
    "typo3/cms-extbase": "^13.4 || ^14.3"
  },
  "require-dev": {
    "phpstan/extension-installer": "^1.4",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^10.5 || ^11.5",
    "saschaegerer/phpstan-typo3": "^3.0",
    "typo3/coding-standards": "^0.8.0",
    "typo3/testing-framework": "^8.2 || ^9.0"
  },
  "suggest": {
    "typo3/cms-fluid-styled-content": "Optional: use site-package layoutRootPaths overrides for themed frame/header partials"
  },
  "autoload": {
    "psr-4": {
      "Mpc\\MpcVidply\\": "Classes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Mpc\\MpcVidply\\Tests\\": "Tests/"
    }
  },
  "config": {
    "vendor-dir": ".Build/vendor",
    "bin-dir": ".Build/bin",
    "allow-plugins": {
      "phpstan/extension-installer": true,
      "typo3/class-alias-loader": true,
      "typo3/cms-composer-installers": true
    }
  },
  "scripts": {
    "test:unit": "phpunit --colors=always -c phpunit.xml.dist",
    "test:functional": "phpunit --colors=always -c Build/FunctionalTests.xml",
    "test:coverage": "phpunit --colors=always -c phpunit.xml.dist --coverage-text --coverage-html .Build/coverage",
    "phpstan": "phpstan analyse -c phpstan.neon.dist --memory-limit=512M",
    "cs": [
      "@putenv PHP_CS_FIXER_IGNORE_ENV=1",
      "php .Build/bin/php-cs-fixer fix --dry-run -v --config .php-cs-fixer.dist.php"
    ],
    "cs:fix": [
      "@putenv PHP_CS_FIXER_IGNORE_ENV=1",
      "php .Build/bin/php-cs-fixer fix -v --config .php-cs-fixer.dist.php"
    ]
  },
  "extra": {
    "typo3/cms": {
      "extension-key": "mpc_vidply",
      "web-dir": ".Build/Public"
    }
  }
}
