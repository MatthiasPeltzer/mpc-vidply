# PHPStan configuration for the mpc_vidply extension.
#
# TYPO3-specific rules and reflection stubs are provided by
# saschaegerer/phpstan-typo3 (auto-registered via phpstan/extension-installer).
parameters:
    level: 8
    paths:
        - Classes
    treatPhpDocTypesAsCertain: false
    ignoreErrors:
        # TYPO3 14 System Resource API is resolved via runtime class-strings so the
        # extension also builds on TYPO3 13.4, where these classes do not exist.
        # On TYPO3 14 the class-strings resolve and the error is not reported.
        -
            identifier: argument.type
            message: '#expects class-string<TYPO3\\CMS\\Core\\SystemResource\\#'
            path: Classes/DataProcessing/VidPlyProcessor.php
            reportUnmatched: false
