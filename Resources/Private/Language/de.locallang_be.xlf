      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_sign_language">
        <source>Sign Language Videos</source>
        <target>Gebärdensprache-Videos</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_sign_language.add">
        <source>Add Sign Language Video</source>
        <target>Gebärdensprach-Video hinzufügen</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_sign_language.description">
        <source>Upload MP4/WebM sign language videos. Use the language field to provide multiple languages.</source>
        <target>Laden Sie MP4-/WebM-Videos mit Gebärdensprache hoch. Verwenden Sie das Sprachfeld, um mehrere Sprachen bereitzustellen.</target>
