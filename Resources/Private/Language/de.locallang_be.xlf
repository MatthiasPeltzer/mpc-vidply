<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<xliff version="1.0">
  <file source-language="en" target-language="de" datatype="plaintext" original="messages" date="2025-11-21T00:00:00Z" product-name="mpc_vidply">
    <header/>
    <body>
      <trans-unit id="content_element.description">
        <source>Universal, accessible video and audio player with support for HTML5, YouTube, Vimeo, HLS/DASH streaming, playlists, captions, and full accessibility features.</source>
        <target>Universeller, barrierefreier Video- und Audio-Player mit Unterstützung für HTML5, YouTube, Vimeo, HLS-/DASH-Streaming, Playlists, Untertitel und umfassenden Barrierefreiheitsfunktionen.</target>
      </trans-unit>
      <trans-unit id="content_element.title">
        <source>VidPly Player</source>
        <target>VidPly Player</target>
      </trans-unit>
      <trans-unit id="preview.external_audio">
        <source>External Audio</source>
        <target>Externes Audio</target>
      </trans-unit>
      <trans-unit id="preview.external_video">
        <source>External Video</source>
        <target>Externes Video</target>
      </trans-unit>
      <trans-unit id="preview.language_fallback">
        <source>Language %d</source>
        <target>Sprache %d</target>
      </trans-unit>
      <trans-unit id="preview.no_media">
        <source>No media items selected</source>
        <target>Keine Medien-Elemente ausgewählt</target>
      </trans-unit>
      <trans-unit id="preview.no_media.hint">
        <source>Please add media items to this VidPly element</source>
        <target>Bitte fügen Sie diesem VidPly-Element Medien-Elemente hinzu</target>
      </trans-unit>
      <trans-unit id="preview.playlist_count">
        <source>Playlist with %d items</source>
        <target>Wiedergabeliste mit %d Elementen</target>
      </trans-unit>
      <trans-unit id="preview.poster_alt">
        <source>Poster for &quot;%s&quot;</source>
        <target>Vorschaubild für &quot;%s&quot;</target>
      </trans-unit>
      <trans-unit id="preview.icon_alt">
        <source>VidPly item</source>
        <target>VidPly-Element</target>
      </trans-unit>
      <trans-unit id="preview.untitled">
        <source>Untitled</source>
        <target>Ohne Titel</target>
      </trans-unit>
      <trans-unit id="tabs.accessibility">
        <source>Accessibility</source>
        <target>Barrierefreiheit</target>
      </trans-unit>
      <trans-unit id="tabs.captions">
        <source>Captions &amp; Chapters</source>
        <target>Untertitel &amp; Kapitel</target>
      </trans-unit>
      <trans-unit id="tabs.media">
        <source>Media</source>
        <target>Medien</target>
      </trans-unit>
      <trans-unit id="tabs.playlist">
        <source>Playlist</source>
        <target>Wiedergabeliste</target>
      </trans-unit>
      <trans-unit id="tabs.settings">
        <source>Player Settings</source>
        <target>Player-Einstellungen</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_audio_description">
        <source>Audio Description</source>
        <target>Audiodeskription</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_audio_description.add">
        <source>Add Audio Description Track</source>
        <target>Audiodeskriptionsspur hinzufügen</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_audio_description.description">
        <source>Upload MP4/WebM video tracks with descriptive audio. Use the language field to provide multiple languages.</source>
        <target>Laden Sie MP4-/WebM-Videospuren mit beschreibendem Audio hoch. Verwenden Sie das Sprachfeld, um mehrere Sprachen bereitzustellen.</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_captions">
        <source>Captions / Subtitles</source>
        <target>Untertitel</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_captions.add">
        <source>Add Caption Track</source>
        <target>Untertitel-Spur hinzufügen</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_captions.description">
        <source>Add WebVTT (.vtt) files for captions and subtitles. Use the language code field for srclang.</source>
        <target>WebVTT (.vtt) Dateien für Untertitel hinzufügen. Verwenden Sie das Sprachcode-Feld für srclang.</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_chapters">
        <source>Chapters</source>
        <target>Kapitel</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_chapters.description">
        <source>Add WebVTT (.vtt) files with chapter information. Use the language code field for srclang.</source>
        <target>WebVTT (.vtt) Dateien mit Kapitelinformationen hinzufügen. Verwenden Sie das Sprachcode-Feld für srclang.</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_language">
        <source>Player Language</source>
        <target>Player-Sprache</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_language.auto">
        <source>Auto (detect from page language)</source>
        <target>Automatisch (aus Seitensprache ermitteln)</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_media">
        <source>Media Files</source>
        <target>Mediendateien</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_media_audio">
        <source>Audio Files (MP3 / WAV / OGG)</source>
        <target>Audiodateien (MP3 / WAV / OGG)</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_media_items">
        <source>Media Items</source>
        <target>Medien-Elemente</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_media_items.add">
        <source>Create new media item</source>
        <target>Neues Medien-Element erstellen</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_media_items.description">
        <source>Select one or more media items from the media library. Add 2+ items to create a playlist.</source>
        <target>Wählen Sie ein oder mehrere Medien-Elemente aus der Medienbibliothek. Fügen Sie 2+ Elemente hinzu, um eine Wiedergabeliste zu erstellen.</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_media_type">
        <source>Media Type</source>
        <target>Medientyp</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_media_type.audio">
        <source>Audio (HTML5)</source>
        <target>Audio (HTML5)</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_media_type.video">
        <source>Video (HTML5)</source>
        <target>Video (HTML5)</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_media_type.vimeo">
        <source>Vimeo</source>
        <target>Vimeo</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_media_type.youtube">
        <source>YouTube</source>
        <target>YouTube</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_media_video">
        <source>Video Files (MP4 / WebM)</source>
        <target>Videodateien (MP4 / WebM)</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_options">
        <source>Player Options</source>
        <target>Player-Optionen</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_options.auto_advance">
        <source>Auto-advance to Next (Playlist)</source>
        <target>Automatisch zum nächsten (Wiedergabeliste)</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_options.autoplay">
        <source>Autoplay</source>
        <target>Automatische Wiedergabe</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_options.captions_default">
        <source>Captions On by Default</source>
        <target>Untertitel standardmäßig aktiviert</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_options.controls">
        <source>Show Controls</source>
        <target>Steuerelemente anzeigen</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_options.keyboard">
        <source>Keyboard Shortcuts</source>
        <target>Tastaturkürzel</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_options.loop">
        <source>Loop</source>
        <target>Wiederholen</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_options.muted">
        <source>Muted</source>
        <target>Stummgeschaltet</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_playback_speed">
        <source>Playback Speed</source>
        <target>Wiedergabegeschwindigkeit</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_playback_speed.description">
        <source>Default playback speed (0.25 - 2.0, default: 1.0)</source>
        <target>Standard-Wiedergabegeschwindigkeit (0.25 - 2.0, Standard: 1.0)</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_playlist">
        <source>Enable Playlist Mode</source>
        <target>Wiedergabelisten-Modus aktivieren</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_playlist_auto_advance">
        <source>Auto-advance to Next Track</source>
        <target>Automatisch zum nächsten Titel wechseln</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_poster">
        <source>Poster Image</source>
        <target>Vorschaubild</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_sign_language">
        <source>Sign Language Videos</source>
        <target>Gebärdensprache-Videos</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_sign_language.add">
        <source>Add Sign Language Video</source>
        <target>Gebärdensprach-Video hinzufügen</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_sign_language.description">
        <source>Upload MP4/WebM sign language videos. Use the language field to provide multiple languages.</source>
        <target>Laden Sie MP4-/WebM-Videos mit Gebärdensprache hoch. Verwenden Sie das Sprachfeld, um mehrere Sprachen bereitzustellen.</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_video_url">
        <source>Video URL</source>
        <target>Video-URL</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_video_url.description">
        <source>For YouTube: https://www.youtube.com/watch?v=VIDEO_ID, For Vimeo: https://vimeo.com/VIDEO_ID</source>
        <target>Für YouTube: https://www.youtube.com/watch?v=VIDEO_ID, Für Vimeo: https://vimeo.com/VIDEO_ID</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_volume">
        <source>Initial Volume</source>
        <target>Anfangslautstärke</target>
      </trans-unit>
      <trans-unit id="tt_content.tx_mpcvidply_volume.description">
        <source>Default volume level (0.0 - 1.0, default: 0.8)</source>
        <target>Standard-Lautstärke (0.0 - 1.0, Standard: 0.8)</target>
      </trans-unit>
      <trans-unit id="tx_mpcvidply_privacy_settings">
        <source>Privacy Layer Settings</source>
        <target>Datenschutz-Einstellungen</target>
      </trans-unit>
    </body>
